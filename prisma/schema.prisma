generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Offer {
  id         String   @id @default(cuid())
  source     String
  sourceId   String
  title      String
  description String?
  price      Float?
  couponDiscountAmount  Float?
  estimatedFinalPrice   Float?
  currency   String?
  imageUrl   String?
  affiliateUrl String
  discountRate Int?
  commissionRate Float?

  // Rating / social proof
  ratingStar     Float?
  soldCount      Int?

  titleHash  String?
  hash       String   @unique
  posted     Boolean  @default(false)
  postedAt   DateTime?
  createdAt  DateTime @default(now())

  // Price drop monitoring
  lastPriceCheckAt      DateTime?
  lastNotifiedDropPrice Float?
  lastNotifiedDropAt    DateTime?

  @@index([source, posted])
  @@index([hash])
}

model BotCursor {
  id              String @id @default("default")
  shopeeKeywordIndex  Int    @default(0)
  shopeeSortTypeIndex Int    @default(0)
  shopeePage          Int    @default(1)
}
