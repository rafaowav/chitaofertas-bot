# ──────────────────────────────────────────────
# Bot — Environment Variables
# ──────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, etc.)
DATABASE_URL=

# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram group / channel chat ID (numeric, can start with -)
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────
# Shopee Affiliate Open API (Source A)
# ──────────────────────────────────────────────
SHOPEE_APP_ID=
SHOPEE_SECRET=
SHOPEE_BASE_URL=https://open-api.affiliate.shopee.com.br/graphql

# ──────────────────────────────────────────────
# Shopee Product Page Scraper (Source B — no longer functional)
# Shopee now blocks all non-browser API calls.
# Bot uses affiliate API pricing only.
# ──────────────────────────────────────────────
SHOPEE_SCRAPE_BASE_URL=https://shopee.com.br

# ──────────────────────────────────────────────
# Scheduling (cron expression)
# ──────────────────────────────────────────────
CRON_INTERVAL="* * * * *"

# ──────────────────────────────────────────────
# General
# ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
