# ──────────────────────────────────────────────
# Bot — Environment Variables
# ──────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, etc.)
DATABASE_URL=

# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram group / channel chat ID (numeric, can start with -)
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────
# Shopee Affiliate Open API (Source A)
# ──────────────────────────────────────────────
SHOPEE_APP_ID=
SHOPEE_SECRET=
SHOPEE_BASE_URL=https://open-api.affiliate.shopee.com.br/graphql

# ──────────────────────────────────────────────
# Shopee Product Page Scraper (Source B — free secondary source)
# Fetches the public product page to extract the real crossed-out price
# No API key required — uses public product data from shopee.com.br
# ──────────────────────────────────────────────
SHOPEE_SCRAPE_BASE_URL=https://shopee.com.br
SHOPEE_SCRAPE_PRICE_DIVISOR=100000
SHOPEE_SCRAPE_TIMEOUT_MS=15000
SHOPEE_SCRAPE_MAX_RETRIES=2

# ──────────────────────────────────────────────
# Scheduling (cron expression)
# ──────────────────────────────────────────────
CRON_INTERVAL="* * * * *"

# ──────────────────────────────────────────────
# General
# ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
